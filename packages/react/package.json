{
  "name": "@oscli-dev/react",
  "version": "0.1.2",
  "description": "React components for oscli demos and interactive CLI previews.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && bunx tsc -p tsconfig.build.json",
    "typecheck": "bunx tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "cli",
    "framework",
    "react",
    "terminal",
    "demo"
  ],
  "author": "Aidan McAlister",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aidankmcalister/oscli.git"
  },
  "homepage": "https://oscli.dev",
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "@oscli-dev/oscli": "^0.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "react": "^19.2.4",
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
