{
  "name": "oscli-workspace",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.2.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "dev": "turbo dev",
    "docs": "cd apps/docs && bun run dev",
    "benchmark": "cd packages/oscli && bun run benchmark"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "turbo": "^2",
    "vitest": "^4.0.18"
  }
}
