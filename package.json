{
  "name": "oscli-workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "docs": "cd docs && bun run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "cd packages/oscli && bun run build",
    "benchmark": "cd packages/oscli && bun run benchmark",
    "typecheck": "cd packages/oscli && bun run typecheck"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vitest": "^4.0.18"
  }
}
