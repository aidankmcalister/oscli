{
  "name": "@oscli-dev/oscli",
  "version": "0.1.0",
  "description": "The last CLI framework you'll reach for.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run examples/kitchen-sink.ts",
    "docs": "cd docs && bun run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "bun build src/index.ts --outdir dist --target node --format esm && bun tsc -p tsconfig.build.json",
    "typecheck": "bun tsc --noEmit",
    "prepublishOnly": "bun run test && bun run build"
  },
  "keywords": [
    "cli",
    "framework",
    "typescript",
    "prompts",
    "terminal",
    "bun"
  ],
  "author": "Aidan McAlister",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aidankmcalister/oscli"
  },
  "homepage": "https://github.com/aidankmcalister/oscli#readme",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1"
  }
}
